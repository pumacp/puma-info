# Copy to .env and fill before running any stack

# Host user mapping for the file-writing stacks (Documents F, Video D manim,
# Publish E uploader). Running those containers as your host user keeps
# bind-mount outputs (output/, public/, documents/, manim_scenes/) owned by you
# instead of root. Defaults to 1000:1000; if your host user is different,
# export the real values before running, e.g.:
#   export PUMA_UID=$(id -u) PUMA_GID=$(id -g)
PUMA_UID=1000
PUMA_GID=1000

# Existing PUMA Ollama (read reference only, do NOT bind)
PUMA_OLLAMA_HOST=localhost:11434

# puma-info dedicated Ollama
PUMA_INFO_OLLAMA_HOST=localhost:11435
PUMA_INFO_OLLAMA_MODEL=qwen2.5:7b

# Hugging Face (optional, only needed for some model downloads)
HF_TOKEN=

# YouTube Data API v3 (only needed for upload step)
YOUTUBE_CREDENTIALS_FILE=secrets/youtube_credentials.json
YOUTUBE_TOKEN_FILE=secrets/youtube_token.json
YOUTUBE_CHANNEL_ID=
