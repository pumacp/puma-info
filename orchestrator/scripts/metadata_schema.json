{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pumacp/puma-info/metadata_schema.json",
  "title": "puma-info YouTube video metadata",
  "type": "object",
  "required": ["video_id", "title", "description", "tags", "category_id", "audio_language"],
  "additionalProperties": false,
  "properties": {
    "video_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1, "maxLength": 100},
    "description": {"type": "string", "maxLength": 5000},
    "tags": {"type": "array", "items": {"type": "string"}, "maxItems": 30},
    "category_id": {"type": "string", "pattern": "^[0-9]+$"},
    "audio_language": {"type": "string", "minLength": 2},
    "default_language": {"type": "string", "minLength": 2},
    "privacy_status": {"type": "string", "enum": ["private", "unlisted", "public"]},
    "localizations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["title", "description"],
        "properties": {
          "title": {"type": "string", "maxLength": 100},
          "description": {"type": "string", "maxLength": 5000}
        }
      }
    }
  }
}
