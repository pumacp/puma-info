# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# Node
node_modules/
.npm/

# Outputs (regeneratable)
output/
translation/input_es/
translation/output_en/
translation/bilingual/
compositions/*/render/
compositions/*/audio/*.wav
compositions/*/audio/*.mp3
manim_scenes/media/
documents/_book/
documents/_site/
imagery/generated/

# Secrets
.env
.env.*
!.env.example
secrets/
*.key
credentials*.json
client_secret*.json

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Docker
.docker_cache/

# Approvals (per-checkout, do not commit)
approvals/*
!approvals/.gitkeep

# Private voice content (reference recordings)
voice/reference/*.wav
voice/reference/*.mp3
voice/reference/*.flac
voice/reference/*.ogg
voice/reference/*.opus
voice/reference/*.m4a
!voice/reference/.gitkeep
