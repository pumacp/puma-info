# Private staging — never published (e.g. wiki working copy)
_private/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# Node
node_modules/
.npm/

# Outputs (regeneratable)
output/
translation/input_es/
translation/output_en/
translation/bilingual/
compositions/*/render/
compositions/*/audio/*.wav
compositions/*/audio/*.mp3
manim_scenes/media/
documents/_book/
documents/_site/
imagery/generated/

# Group F · Documents (generated outputs / build side-files)
documents/quarto/*_files/
documents/quarto/*.html
documents/quarto/.quarto/
documents/marp/*.html

# Group D · Video (regeneratable / not tracked)
compositions/*/.hyperframes/
compositions/*/node_modules/
compositions/*/preview/
manim_scenes/__pycache__/
# HyperFrames skill bundles install locally per checkout, never tracked.
# The `skills` CLI installs an agent-agnostic bundle under .agents/; some
# agents use .claude/ — ignore both so the public remote stays brand-free.
compositions/*/.agents/
compositions/*/.claude/
# Skills-installer lock file (regenerated locally, not tracked)
compositions/*/skills-lock.json

# Secrets
.env
.env.*
!.env.example
secrets/
*.key
credentials*.json
client_secret*.json

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Docker
.docker_cache/

# Approvals (per-checkout, do not commit)
approvals/*
!approvals/.gitkeep

# Private voice content (reference recordings)
voice/reference/*.wav
voice/reference/*.mp3
voice/reference/*.flac
voice/reference/*.ogg
voice/reference/*.opus
voice/reference/*.m4a
!voice/reference/.gitkeep

# Named public projects — outputs are regeneratable (mirror of root rules)
public/*/output/
public/*/compositions/*/render/
public/*/compositions/*/audio/*.wav
public/*/manim_scenes/media/
