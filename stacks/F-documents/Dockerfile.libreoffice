# LibreOffice headless — .pptx import (to pdf/html) and document conversion
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        libreoffice-impress libreoffice-writer fonts-liberation ca-certificates \
    && rm -rf /var/lib/apt/lists/*

LABEL puma_info="true"

WORKDIR /work
CMD ["sleep", "infinity"]
